# =============================================================================
# My Toolbox - Environment Variables
# Copy this file to `.env` and fill in real values.
# Never commit `.env` to git.
# =============================================================================

# --- Flask core ---
FLASK_ENV=production
SECRET_KEY=please-change-me-to-a-long-random-string-at-least-32-chars
# APP_BASE_URL is used in emails / OG tags. Include scheme + host, no trailing slash.
APP_BASE_URL=https://toolbox.example.com

# --- Database ---
# Default: SQLite inside instance/. Swap to PostgreSQL URI for scale-up.
DATABASE_URL=sqlite:///app.db

# --- Bootstrap admin (created on first run) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# --- AI image provider ---
# Pick one: "openai" | "siliconflow" | "mock"
AI_PROVIDER=mock
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-image-1

# --- Limits & behavior ---
DAILY_FREE_LIMIT=10
ANON_FREE_LIMIT=3
MAX_UPLOAD_MB=25
TEMP_FILE_TTL_MINUTES=30

# --- Rate limit (Flask-Limiter) ---
RATELIMIT_DEFAULT=120/minute
RATELIMIT_TOOL=20/minute

# --- Server binding (used by gunicorn / local dev) ---
HOST=127.0.0.1
PORT=8000

# --- Timezone (display only; DB stores UTC) ---
DISPLAY_TIMEZONE=Asia/Shanghai
